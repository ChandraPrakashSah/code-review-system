#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# Claude AI Code Review — Pre-commit Hook
# Runs automatically before every git commit.
# Logs usage to review-logs/reviews.csv so the team lead can track compliance.
# ─────────────────────────────────────────────────────────────────────────────

# Load user shell profile so PATH includes claude, nvm, brew, etc.
[ -f "$HOME/.zshrc" ]   && source "$HOME/.zshrc"   2>/dev/null
[ -f "$HOME/.bashrc" ]  && source "$HOME/.bashrc"  2>/dev/null
[ -f "$HOME/.profile" ] && source "$HOME/.profile" 2>/dev/null
export PATH="$HOME/.npm-global/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

REPO_ROOT=$(git rev-parse --show-toplevel)
PROMPT_FILE="$REPO_ROOT/.githooks/review-prompt.md"
LOG_FILE="$REPO_ROOT/review-logs/reviews.csv"
REVIEW_DIR="$REPO_ROOT/review-logs"

GIT_USER=$(git config user.name 2>/dev/null || echo "unknown")
GIT_EMAIL=$(git config user.email 2>/dev/null || echo "unknown")
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

mkdir -p "$REVIEW_DIR"

# Write CSV header if log file does not exist yet
if [ ! -f "$LOG_FILE" ]; then
  echo "timestamp,username,email,branch,staged_files,status" > "$LOG_FILE"
fi

# ── Check dependencies ────────────────────────────────────────────────────────
if ! command -v claude &>/dev/null; then
  echo ""
  echo "⚠️  'claude' CLI not found. Install Claude Code to enable AI reviews."
  echo "   Commit will proceed without review."
  echo ""
  STAGED_FILES=$(git diff --cached --name-only | tr '\n' ' ')
  echo "\"$TIMESTAMP\",\"$GIT_USER\",\"$GIT_EMAIL\",\"$BRANCH\",\"$STAGED_FILES\",\"CLAUDE_NOT_INSTALLED\"" >> "$LOG_FILE"
  exit 0
fi

if [ ! -f "$PROMPT_FILE" ]; then
  echo "⚠️  Review prompt not found at $PROMPT_FILE. Skipping review."
  exit 0
fi

# ── Get staged diff ───────────────────────────────────────────────────────────
DIFF=$(git diff --cached)

if [ -z "$DIFF" ]; then
  echo "ℹ️  No staged changes found. Skipping review."
  exit 0
fi

STAGED_FILES=$(git diff --cached --name-only | tr '\n' ' ')

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🤖  Claude AI Code Review"
echo "  Developer : $GIT_USER <$GIT_EMAIL>"
echo "  Branch    : $BRANCH"
echo "  Files     : $STAGED_FILES"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Build full prompt = template + diff
PROMPT="$(cat "$PROMPT_FILE")

$DIFF"

# Run Claude review (non-interactive print mode)
REVIEW_OUTPUT=$(claude -p "$PROMPT" 2>&1)
CLAUDE_EXIT=$?

if [ $CLAUDE_EXIT -ne 0 ]; then
  echo "⚠️  Claude review failed (exit $CLAUDE_EXIT). Output:"
  echo "$REVIEW_OUTPUT"
  echo ""
  echo "\"$TIMESTAMP\",\"$GIT_USER\",\"$GIT_EMAIL\",\"$BRANCH\",\"$STAGED_FILES\",\"REVIEW_FAILED\"" >> "$LOG_FILE"
else
  echo "$REVIEW_OUTPUT"
  echo ""
  echo "\"$TIMESTAMP\",\"$GIT_USER\",\"$GIT_EMAIL\",\"$BRANCH\",\"$STAGED_FILES\",\"REVIEWED\"" >> "$LOG_FILE"
fi

# ── Ask user to confirm or abort the commit ───────────────────────────────────
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exec < /dev/tty
read -r -p "  Proceed with commit? (y/n): " PROCEED
echo ""

if [[ "$PROCEED" != "y" && "$PROCEED" != "Y" ]]; then
  echo "  Commit aborted by $GIT_USER."
  echo "\"$TIMESTAMP\",\"$GIT_USER\",\"$GIT_EMAIL\",\"$BRANCH\",\"$STAGED_FILES\",\"COMMIT_ABORTED\"" >> "$LOG_FILE"
  exit 1
fi

exit 0
